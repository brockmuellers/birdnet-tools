# Copy to .env and fill in real values. Never commit .env.
BIRDNETPI_DB_PATH=<path_to_birdnetpi>/scripts/birds.db
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=birdnet-data
R2_OBJECT_KEY=birdnet-data.json
# EXPORT_OUTPUT_PATH=/tmp/birdnet_export.json  # optional, this is the default
